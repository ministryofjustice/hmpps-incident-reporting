{% from "govuk/components/error-message/macro.njk" import govukErrorMessage %}
{% from "govuk/components/fieldset/macro.njk" import govukFieldset %}
{% from "govuk/components/hint/macro.njk" import govukHint %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% macro renderTimeFields(fieldName, field, options, values, errors) %}

  <div class="govuk-form-group {% if errors[fieldName] %}govuk-form-group--error{% endif %}">
    {% call govukFieldset({
      legend: {
        text: field.label,
        classes: "govuk-fieldset__legend--m"
      }
    }) %}

      {% if field.hint %}
        {{ govukHint({
          text: field.hint
        }) }}
      {% endif %}

      {% if errors[fieldName] %}
        {{ govukErrorMessage({
          text: errors[fieldName].message
        }) }}
      {% endif %}

      {% set timeInputFieldClasses = "govuk-date-input__input govuk-input--width-2" %}

      <div id="{{ fieldName }}" class="govuk-date-input">
        <div class="govuk-date-input__item">
          {{ govukInput({
            name: fieldName + "_hours",
            id: fieldName + "_hours",
            label: {
              text: "Hours",
              classes: "govuk-date-input__label"
            },
            classes: timeInputFieldClasses + " govuk-input--error" if errors[fieldName] else timeInputFieldClasses,
            inputmode: "numeric",
            value: values[fieldName]
          }) }}
        </div>
        <div class="govuk-date-input__item">
          {{ govukInput({
            name: fieldName + "_minutes",
            id: fieldName + "_minutes",
            label: {
              text: "Minutes",
              classes: "govuk-date-input__label"
            },
            classes: timeInputFieldClasses + " govuk-input--error" if errors[fieldName] else timeInputFieldClasses,
            inputmode: "numeric",
            value: values[fieldName]
          }) }}
        </div>
      </div>

    {% endcall %}
  </div>

{% endmacro %}
